<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.simplepetmanager.model.mapper.UserMapper">
    <!-- 회원가입 -->
    <insert id="register" parameterType="com.project.simplepetmanager.model.dto.User">
        INSERT INTO users
        (user_id, user_password, user_name, user_email, created_date)
        VALUES
            (#{userId}, #{userPassword}, #{userName}, #{userEmail}, NOW())
    </insert>

    <!-- 이메일 중복 체크 -->
    <select id="checkEmail" parameterType="String" resultType="int">
        SELECT COUNT(*)
        FROM users
        WHERE user_email = #{userEmail}
    </select>

    <!-- 로그인 유저확인 -->
    <select id="login" parameterType="String" resultType="com.project.simplepetmanager.model.dto.User">
        SELECT *
        FROM users
        WHERE user_email = #{userEmail}
    </select>

    <!-- 로그인 기능 -->
    <select id="findByUserId" parameterType="String" resultType="com.project.simplepetmanager.model.dto.User">
        SELECT
        user_number,user_id,user_password,user_name,user_email,profile_image,image_url
        FROM users
        WHERE user_id = #{userId}
    </select>

</mapper>