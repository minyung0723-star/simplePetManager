<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.simplepetmanager.model.mapper.BookmarkMapper">

    <!--
        TODO : getBookmarkListByUser 쿼리 개선
        파라미터   : userNumber (int)
        반환       : List<BookMark>
        현재       : bookmark 테이블 단독 조회 (store_name, store_address 가 bookmark 에 중복 저장됨)
        수정 방향  : stores 테이블과 JOIN 해서 store_name, store_address, store_image 를 가져올 것
                     → BookMark.java 에 storeImage 필드 추가도 함께 필요
    -->
    <select id="getBookmarkListByUser" parameterType="int" resultType="com.project.simplepetmanager.model.dto.BookMark">
        SELECT
            b.storeId,          -- 북마크 고유 번호
            b.user_number    AS userNumber,
            s.store_id       AS storeId,
                -- stores 테이블에서 가져옴
                -- stores 테이블에서 가져옴
            s.store_phone    AS storePhone,
            s.category,
            s.latitude,
            s.longitude,
            s.store_image    AS storeImage    -- 추가된 요구사항
        FROM bookmark b
                 INNER JOIN stores s ON b.storeId = s.store_id
        WHERE b.user_number = #{userNumber}
    </select>

    <!--
        파라미터 : userNumber (int), storeId (int)
        반환     : int — 0이면 즐겨찾기 없음, 1 이상이면 이미 존재
    -->
    <select id="checkBookmarkExists" resultType="int">
        SELECT COUNT(*)
        FROM bookmark
        WHERE user_number = #{userNumber}
          AND storeid = #{storeId}
    </select>

    <!--
        TODO : insertBookmarkList 쿼리 수정
        파라미터   : BookMark 객체 (user_number, storeId)
        현재       : Store_name, Store_address 를 bookmark 테이블에 직접 저장 → 중복 데이터 문제
        수정 방향  : INSERT INTO bookmark (user_number, storeid, prefer)
                     VALUES (#{user_number}, #{storeId}, 1)
                     가게 정보는 stores JOIN 으로 가져오면 되므로 bookmark 에 저장 불필요
    -->
    <insert id="insertBookmarkList">
        INSERT INTO bookmark (user_number, Storeid, prefer)
        VALUES (#{user_number}, #{storeId},1)
    </insert>

    <!--
        파라미터 : userNumber (int), storeId (int)
        동작     : bookmark 테이블에서 해당 row 삭제 (하트 토글 해제)
    -->
    <delete id="deleteBookmark">
        DELETE FROM bookmark
        WHERE user_number = #{userNumber}
          AND storeid = #{storeId}
    </delete>

</mapper>