<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.simplepetmanager.model.mapper.BoardMapper">

    <select id="selectStoreList" resultType="com.project.simplepetmanager.model.dto.Board">
        SELECT *
        FROM stores
        <where>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="keyword != null and keyword != ''">
                <choose>
                    <when test="searchType == 'name'">
                        AND store_name LIKE CONCAT('%', #{keyword}, '%')
                    </when>
                    <when test="searchType == 'address'">
                        AND store_address LIKE CONCAT('%', #{keyword}, '%')
                    </when>
                    <otherwise>
                        AND (store_name  LIKE CONCAT('%', #{keyword}, '%')
                        OR   store_address LIKE CONCAT('%', #{keyword}, '%'))
                    </otherwise>
                </choose>
            </if>
        </where>
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="countStores" resultType="int">
        SELECT COUNT(*)
        FROM stores
        <where>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="keyword != null and keyword != ''">
                <choose>
                    <when test="searchType == 'name'">
                        AND store_name LIKE CONCAT('%', #{keyword}, '%')
                    </when>
                    <when test="searchType == 'address'">
                        AND store_address LIKE CONCAT('%', #{keyword}, '%')
                    </when>
                    <otherwise>
                        AND (store_name  LIKE CONCAT('%', #{keyword}, '%')
                        OR   store_address LIKE CONCAT('%', #{keyword}, '%'))
                    </otherwise>
                </choose>
            </if>
        </where>
    </select>

    <select id="selectStoreById" resultType="com.project.simplepetmanager.model.dto.Board">
        SELECT
            store_id      AS storeId,
            store_name    AS storeName,
            store_phone   AS storePhone,
            store_address AS storeAddress,
            category,
            latitude,
            longitude,
            store_image   AS storeImage
        FROM stores
        WHERE store_id = #{storeId}
    </select>

</mapper>
