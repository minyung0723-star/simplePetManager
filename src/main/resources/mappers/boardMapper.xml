<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- boardMapper.xml -->
<mapper namespace="com.project.simplepetmanager.model.mapper.BoardMapper">
    <select id="getStoreList" resultType="com.project.simplepetmanager.model.dto.Board">
        SELECT * FROM stores LIMIT 1 OFFSET 1
    </select>
    <insert id="insertBookmark">
        INSERT INTO bookmark (user_number, storeId, prefer)
        VALUES (#{userNumber}, #{storeId}, 1)
    </insert>
</mapper>